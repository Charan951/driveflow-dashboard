# Pentest remediation — environment variables

## Auth / JWT
JWT_SECRET=your_jwt_secret
JWT_ACCESS_EXPIRES_IN=15m
# Optional: set for cross-subdomain cookies in production (e.g. .carzzi.com)
# COOKIE_DOMAIN=.carzzi.com
# Set to true only for emergency rollback of legacy login/register in production
ALLOW_LEGACY_AUTH=false

## Public booking tracking tokens
TRACKING_TOKEN_SECRET=your_tracking_token_secret

## Resume uploads (optional private prefix)
AWS_S3_RESUME_PREFIX=carzzi_resumes/
