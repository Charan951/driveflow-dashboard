# Application environment: development | testing | production
# development & production: send auth OTPs via MSG91 (WhatsApp/SMS as configured)
# testing: no WhatsApp/SMS OTP; signup/login skip OTP step (password + details only)
APP_ENV=development

# MSG91 — signup OTP
MSG91_AUTH_KEY=your_msg91_auth_key

# Option A: MSG91 OTP API (SMS / OTP route) — use Template ID from OTP → Templates (NOT the template name)
MSG91_OTP_TEMPLATE_ID=679a05f7d6fc05753b6d9b82
# MSG91_OTP_FLOW_ID=optional_if_different_from_template_id

# WhatsApp OTP templates (template names from MSG91 → WhatsApp → Templates)
MSG91_WHATSAPP_AUTH_TEMPLATE_NAME=user_authentication
MSG91_WHATSAPP_ASSIGNED_TEMPLATE_NAME=general_service
MSG91_WHATSAPP_FEEDBACK_TEMPLATE_NAME=feedback
MSG91_WHATSAPP_TEMPLATE_NAME=otp
MSG91_WHATSAPP_INTEGRATED_NUMBER=919876543210
MSG91_WHATSAPP_NAMESPACE=your_meta_template_namespace
MSG91_WHATSAPP_LANGUAGE=en
# Also send same OTP via SMS if WhatsApp is slow or fails (recommended: true)
MSG91_SIGNUP_SMS_FALLBACK=true
