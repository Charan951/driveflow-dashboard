{
  "info": {
    "name": "Carzzi Cashfree Payments",
    "_postman_id": "9ec4376b-5e2d-4512-90ec-29f39c6b5eb3",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/payments/create-order",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 499,\n  \"currency\": \"INR\",\n  \"tempBookingData\": {\n    \"requiresPaymentService\": true,\n    \"totalAmount\": 499,\n    \"date\": \"2026-05-08T10:00:00.000Z\"\n  }\n}"
        }
      }
    },
    {
      "name": "Verify Payment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/payments/verify",
        "body": { "mode": "raw", "raw": "{\n  \"orderId\": \"{{orderId}}\"\n}" }
      }
    },
    {
      "name": "Retry Payment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/payments/retry",
        "body": { "mode": "raw", "raw": "{\n  \"orderId\": \"{{orderId}}\"\n}" }
      }
    },
    {
      "name": "Webhook Sample",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-webhook-signature", "value": "{{signature}}" },
          { "key": "x-webhook-timestamp", "value": "{{timestamp}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/payments/webhook",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"PAYMENT_SUCCESS_WEBHOOK\",\n  \"data\": {\n    \"order\": {\n      \"order_id\": \"{{orderId}}\"\n    },\n    \"payment\": {\n      \"cf_payment_id\": \"123456\"\n    }\n  }\n}"
        }
      }
    }
  ]
}
